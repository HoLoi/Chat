<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_profile">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:weightSum="7">

        <ImageView
            android:id="@+id/btn_back_informationI"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/ic_arrow_back"
            android:layout_gravity="center"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="5"
            android:text="Thông tin người dùng"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <ImageView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>
    </LinearLayout>


    <!-- CARD THÔNG TIN -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="180dp"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:padding="20dp"
        android:elevation="6dp">

        <!-- Họ tên -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_input_information"
            android:padding="14dp"
            android:layout_marginTop="70dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:text="Họ tên"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/edt_hotenI"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:textSize="16sp"
                android:hint="Nhập họ tên"/>
        </LinearLayout>


        <!-- Số điện thoại -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_input_information"
            android:padding="14dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:text="Số di động"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/edt_didongI"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:textSize="16sp"
                android:inputType="phone"
                android:hint="Nhập di động"/>
        </LinearLayout>


        <!-- Ngày sinh -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_input_information"
            android:padding="14dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:text="Ngày sinh"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/edtNgaySinhI"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:textSize="16sp"
                android:hint="Chọn ngày sinh"
                android:focusable="false"
                android:inputType="none"/>
        </LinearLayout>


        <!-- Giới tính -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_input_information"
            android:padding="14dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:text="Giới tính"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <RadioGroup
                android:id="@+id/radioGroupGioiTinhI"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/radioBtnNamI"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nam"/>

                <RadioButton
                    android:id="@+id/radioBtnNuI"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nữ"
                    android:layout_marginStart="30dp"/>

            </RadioGroup>

        </LinearLayout>


        <Button
            android:id="@+id/btn_capnhat_information"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Cập Nhật"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#2F80ED"/>

    </LinearLayout>


    <!-- AVATAR -->
    <FrameLayout
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_gravity="top|center"
        android:layout_marginTop="110dp"
        android:elevation="8dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imageviewavatarI"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/avatar_default"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/CircularImage"/>

        <ImageView
            android:id="@+id/imageviewEditavatarI"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="end|bottom"
            android:src="@drawable/ic_edit"/>

    </FrameLayout>

</FrameLayout>