<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F6F7FB">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="16dp"
        android:background="@drawable/background_main">

        <ImageView
            android:id="@+id/iv_back_menu_chat"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:padding="6dp"
            android:background="@drawable/bg_circle_light"
            android:src="@drawable/ic_back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="Tùy chọn nhóm"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- GROUP INFO CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@drawable/bg_card">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_menu_avatar"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:src="@drawable/avatar_default"
                    app:shapeAppearanceOverlay="@style/CircularImage" />

                <TextView
                    android:id="@+id/tv_tenphong"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="Tên nhóm"
                    android:textColor="#111827"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            </LinearLayout>


            <!-- GROUP ACTIONS -->
            <LinearLayout
                android:id="@+id/layout_group_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="8dp">

                <Button
                    android:id="@+id/btn_rename_group"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Đổi tên nhóm"
                    android:textAllCaps="false"
                    android:gravity="start|center_vertical"
                    android:paddingStart="14dp"
                    android:textColor="#1F2937"
                    app:backgroundTint="@null"
                    android:background="@drawable/bg_menu_item"/>

                <Button
                    android:id="@+id/btn_change_avatar"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Đổi ảnh đại diện"
                    android:textAllCaps="false"
                    android:gravity="start|center_vertical"
                    android:paddingStart="14dp"
                    android:layout_marginTop="6dp"
                    android:textColor="#1F2937"
                    app:backgroundTint="@null"
                    android:background="@drawable/bg_menu_item"/>

                <Button
                    android:id="@+id/btn_view_members"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Xem thành viên"
                    android:textAllCaps="false"
                    android:gravity="start|center_vertical"
                    android:paddingStart="14dp"
                    android:layout_marginTop="6dp"
                    android:textColor="#1F2937"
                    app:backgroundTint="@null"
                    android:background="@drawable/bg_menu_item"/>

                <Button
                    android:id="@+id/btn_add_members"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Thêm thành viên"
                    android:textAllCaps="false"
                    android:gravity="start|center_vertical"
                    android:paddingStart="14dp"
                    android:layout_marginTop="6dp"
                    android:textColor="#1F2937"
                    app:backgroundTint="@null"
                    android:background="@drawable/bg_menu_item"/>

                <Button
                    android:id="@+id/btn_toggle_privacy"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Chuyển Public/Private"
                    android:textAllCaps="false"
                    android:gravity="start|center_vertical"
                    android:paddingStart="14dp"
                    android:layout_marginTop="6dp"
                    android:textColor="#1F2937"
                    app:backgroundTint="@null"
                    android:background="@drawable/bg_menu_item"/>

                <Button
                    android:id="@+id/btn_pending_requests"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Duyệt yêu cầu tham gia"
                    android:textAllCaps="false"
                    android:gravity="start|center_vertical"
                    android:paddingStart="14dp"
                    android:layout_marginTop="6dp"
                    android:textColor="#1F2937"
                    app:backgroundTint="@null"
                    android:background="@drawable/bg_menu_item"/>

                <!--                <TextView-->
                <!--                    android:id="@+id/tv_group_note"-->
                <!--                    android:layout_width="match_parent"-->
                <!--                    android:layout_height="wrap_content"-->
                <!--                    android:layout_marginTop="10dp"-->
                <!--                    android:text="Các thao tác quản trị chỉ hiển thị cho trưởng nhóm"-->
                <!--                    android:textColor="#6B7280"-->
                <!--                    android:textSize="13sp" />-->

            </LinearLayout>

        </LinearLayout>
    </ScrollView>


    <!-- LEAVE GROUP -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#FFF1F2">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_delete" />

        <TextView
            android:id="@+id/tv_delete_leave"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Rời nhóm"
            android:textColor="#D92D20"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>

