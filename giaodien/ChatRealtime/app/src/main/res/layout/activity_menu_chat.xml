<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F6FA">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="16dp"
        android:background="@drawable/background_main">

        <ImageView
            android:id="@+id/iv_back_menu_chat"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:background="@drawable/bg_circle_light"
            android:src="@drawable/ic_back" />

        <TextView
            android:id="@+id/tv_title_menu_chat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:text="Tùy chọn"
            android:textColor="@android:color/white"
            android:textSize="19sp"
            android:textStyle="bold" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Thông tin phòng -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="@drawable/bg_card">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_menu_avatar"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:src="@drawable/avatar_default"
                    app:shapeAppearanceOverlay="@style/CircularImage" />

                <TextView
                    android:id="@+id/tv_tenphong"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="Tên phòng"
                    android:textColor="#111827"
                    android:textSize="21sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_group_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:text="Nhóm riêng tư"
                    android:textColor="#6B7280"
                    android:textSize="14sp" />

                <!-- quick actions -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <LinearLayout
                        android:id="@+id/lnlayout_trangcanhan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/iv_call"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:padding="10dp"
                            android:background="@drawable/bg_circle_action"
                            android:src="@android:drawable/ic_menu_myplaces"/>

                        <TextView
                            android:id="@+id/tv_call"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Trang cá nhân"
                            android:textColor="#1F2933"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/lnlayout_voice_call"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:padding="10dp"
                            android:background="@drawable/bg_circle_action"
                            android:src="@android:drawable/ic_menu_call"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Gọi thoại"
                            android:textColor="#1F2933"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/lnlayout_video_call"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:padding="10dp"
                            android:background="@drawable/bg_circle_action"
                            android:src="@android:drawable/ic_menu_slideshow"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Gọi video"
                            android:textColor="#1F2933"
                            android:textSize="13sp"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

            <!-- Thành viên -->
            <TextView
                android:id="@+id/tv_member_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Thành viên"
                android:textColor="#111827"
                android:textSize="17sp"
                android:textStyle="bold"
                android:visibility="gone"/>

            <ListView
                android:id="@+id/lv_members"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:divider="@android:color/transparent"
                android:dividerHeight="8dp"
                android:visibility="gone"/>

            <!-- quản trị -->
            <LinearLayout
                android:id="@+id/layout_group_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/bg_card"
                android:visibility="gone">

                <Button
                    android:id="@+id/btn_rename_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Đổi tên nhóm"
                    android:textAllCaps="false"/>

                <Button
                    android:id="@+id/btn_change_avatar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Đổi ảnh đại diện"
                    android:textAllCaps="false"/>

                <Button
                    android:id="@+id/btn_view_members"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Xem thành viên"
                    android:textAllCaps="false"/>

                <Button
                    android:id="@+id/btn_add_members"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Thêm thành viên"
                    android:textAllCaps="false"/>

                <Button
                    android:id="@+id/btn_toggle_privacy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Chuyển Public/Private"
                    android:textAllCaps="false"/>

                <Button
                    android:id="@+id/btn_pending_requests"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Duyệt yêu cầu tham gia"
                    android:textAllCaps="false"/>

                <TextView
                    android:id="@+id/tv_group_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Dùng các nút trên để đổi tên, đổi ảnh và quản lý thành viên"
                    android:textColor="#6B7280"
                    android:textSize="13sp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- danger -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:background="#FFF1F2">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_delete"/>

        <TextView
            android:id="@+id/tv_delete_leave"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Xóa hoặc rời cuộc trò chuyện"
            android:textColor="#D92D20"
            android:textSize="16sp"
            android:textStyle="bold"/>
    </LinearLayout>

</LinearLayout>