<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA"
    android:id="@+id/main">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@drawable/background_main"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnBackTerms"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Điều khoản và Chính sách"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_weight="1"/>

    </LinearLayout>


    <!-- CONTENT -->
    <ScrollView
        android:id="@+id/scrollTerms"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/layoutBottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp">

            <!-- TITLE -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Điều khoản sử dụng"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#111827"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Không sử dụng ứng dụng cho mục đích xấu.\n2. Không spam hoặc phát tán nội dung độc hại.\n3. Cung cấp thông tin chính xác khi đăng ký.\n4. Hệ thống có quyền khóa tài khoản nếu vi phạm."
                android:textSize="14sp"
                android:textColor="#374151"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="6dp"/>

            <!-- SPACE -->
            <View
                android:layout_width="match_parent"
                android:layout_height="12dp"/>

            <!-- POLICY -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chính sách bảo mật"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#111827"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Thông tin cá nhân của bạn được bảo mật.\n2. Không chia sẻ dữ liệu cho bên thứ ba khi chưa có sự đồng ý.\n3. Dữ liệu chỉ được sử dụng để cải thiện trải nghiệm."
                android:textSize="14sp"
                android:textColor="#374151"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="6dp"/>

            <!-- SPACE -->
            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"/>

            <!-- FEEDBACK LINK -->
            <TextView
                android:id="@+id/tvFeedbackLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📩 Gửi góp ý hoặc báo lỗi"
                android:textColor="#2563EB"
                android:textStyle="bold"
                android:textSize="14sp"/>

        </LinearLayout>

    </ScrollView>


    <!-- FOOTER -->
    <LinearLayout
        android:id="@+id/layoutBottom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <CheckBox
            android:id="@+id/cbAgree"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tôi đã đọc và đồng ý"
            android:textColor="#111827"/>

        <Button
            android:id="@+id/btnAgree"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:text="Tiếp tục"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:enabled="false"
            app:backgroundTint="@null"
            android:background="@drawable/bg_button_addfriend"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>