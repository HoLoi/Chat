<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/bg_profile"
    android:padding="10dp"
    android:weightSum="14"
    android:id="@+id/main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="horizontal"
        android:weightSum="5"
        android:layout_marginBottom="5dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Đăng Nhập"
            android:textSize="35sp"
            android:textColor="#000000"
            android:textStyle="bold"
            android:fontFamily="sans-serif"
            android:layout_gravity="center"
            android:gravity="center"
            android:layout_weight="3"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Tạo tài khoản"
            android:textSize="18sp"
            android:textColor="#9E9D9D"
            android:textStyle="bold"
            android:layout_gravity="bottom|right"
            android:gravity="center"
            android:layout_weight="2"
            android:id="@+id/tv_taotk"/>


    </LinearLayout>

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:src="@drawable/logo_chat"
        android:layout_gravity="center"
        android:layout_weight="5"/>

    <ProgressBar
        android:id="@+id/progressBarSignIn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_gravity="center" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="4"
        android:orientation="vertical"
        android:weightSum="2"
        android:layout_marginTop="10dp">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/textInputLayout_singin"
            android:hint="E-Mail"
            app:startIconDrawable="@drawable/ic_email"
            android:id="@+id/textInputLayoutEmail">

            <com.google.android.material.textfield.TextInputEditText
                style="@style/textInputEditText_singin"
                android:id="@+id/textInputEditTextEmail" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/textInputLayout_singin"
            android:hint="Mật khẩu"
            app:startIconDrawable="@drawable/ic_password_signup"
            app:passwordToggleEnabled="true"
            app:endIconMode="password_toggle"
            android:id="@+id/textInputLayoutPassword">

            <com.google.android.material.textfield.TextInputEditText
                style="@style/textInputEditText_singin"
                android:id="@+id/textInputEditTextPassword"
                android:inputType="textPassword" />

        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_weight="1">

        <CheckBox
            android:id="@+id/checkBoxNhoDangNhap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/white"
            android:textColor="@color/white"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ghi Nho Dang Nhap"
            android:textColor="@color/white"/>

    </LinearLayout>

    <Button
        android:id="@+id/btn_signin"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:text="ĐĂNG NHẬP"
        android:textSize="20sp"
        android:textColor="#ffffff"
        android:textStyle="bold"
        android:backgroundTint="#B0AFEF"
        android:layout_marginLeft="30dp"
        android:layout_marginRight="30dp"
        android:layout_weight="1"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:text="Quên mật khẩu"
        android:layout_gravity="center"
        android:layout_marginBottom="10dp"
        android:layout_weight="1"
        android:textColor="@color/white"
        android:id="@+id/tv_forgot_password"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>