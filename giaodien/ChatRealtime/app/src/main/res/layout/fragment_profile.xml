<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_profile"
    android:padding="20dp"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/avatarImage"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:src="@drawable/avatar_default"
            app:shapeAppearanceOverlay="@style/CircularImage"
            android:layout_gravity="center"
            android:scaleType="centerCrop" />


        <TextView
            android:id="@+id/tv_tenUser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:textSize="25sp"
            android:textStyle="bold"
            android:layout_margin="10dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_rounded_profile"
        android:orientation="vertical"
        android:padding="10dp"
        android:layout_marginTop="5dp">

        <Button
            android:id="@+id/btnThongTinSinhVien"
            style="@style/btn_profile"
            android:text="Thông tin cá nhân"
            android:drawableLeft="@drawable/ic_profile" />
        <Button
            android:id="@+id/btnDoiMatKhau"
            style="@style/btn_profile"
            android:text="Đổi mật khẩu"
            android:drawableLeft="@drawable/ic_password_signup"/>
        <Button
            style="@style/btn_profile"
            android:text="Điều khoản và chính sách sử dụng"
            android:drawableLeft="@drawable/ic_profile"/>
        <Button
            style="@style/btn_profile"
            android:text="Góp ý ứng dụng"
            android:drawableLeft="@drawable/ic_profile"/>
        <Button
            android:id="@+id/btnDangXuat"
            style="@style/btn_profile"
            android:text="Đăng xuất"
            android:drawableLeft="@drawable/ic_signout"/>
    </LinearLayout>

</LinearLayout>